---
export const prerender = true;
import Base from '../layouts/Base.astro';
const title = "Numetal — BOUNTY + PLATES retrodrop";
const description = "500M $NUMETAL retrodropped to the real holders of BOUNTY + PLATES, snapshotted at the Numetal launch block. Methodology, full recipient list, live batch tracker — no signing.";
const canonical = 'https://numetal.xyz/airdrops';
const bodyHtml = `<style>
  :root{--ikb:#002FA7;--paper:#FAFAF8;--ink:#141414;--orange:#FF5A1F;--cyan:#0791a6;--green:#0F8A4C;--line:#cfcfcf;--hard:#8c8c8c;--muted:#7c7c7c;
    --mono:ui-monospace,'SF Mono','SFMono-Regular',Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,'Liberation Sans',sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-font-smoothing:antialiased}
  body{background:var(--paper);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5;min-height:100vh;display:flex;flex-direction:column}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .wrap{width:100%;max-width:1060px;margin:0 auto;padding:0 28px}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  header{border-bottom:1px solid var(--ink);position:sticky;top:0;background:var(--paper);z-index:5}
  .bar{display:flex;align-items:center;justify-content:space-between;height:54px;max-width:1060px;margin:0 auto;padding:0 28px}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.04em;font-size:17px}
  .mark a{color:var(--ink)}.mark .sq{width:13px;height:13px;background:var(--ikb)}
  nav{display:flex;gap:20px;font-size:13px;align-items:center}
  nav a{color:var(--ink)}nav .upd{color:var(--muted)}nav a.on{font-weight:700}
  main{flex:1}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}
  .dotp{width:7px;height:7px;border-radius:50%;background:var(--cyan);display:inline-block;animation:pulse 1.8s ease-in-out infinite}
  .intro{padding:54px 0 22px}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:20px}
  h1{font-size:clamp(36px,6.5vw,64px);line-height:1.0;font-weight:700;letter-spacing:-.03em}
  h1 .dot{color:var(--ikb)}
  .sub{font-size:17px;color:#333;margin-top:18px;max-width:62ch;line-height:1.55}
  .hstat{font-family:var(--mono);font-size:12px;letter-spacing:.05em;text-transform:uppercase;color:var(--ink);margin-top:22px;display:flex;align-items:center;gap:9px}
  .sec{padding:34px 0 0}
  .sh{display:flex;align-items:baseline;gap:11px;font-family:var(--mono);font-size:13px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;margin-bottom:8px}
  .sh .ix{color:var(--muted)}
  .sdot{height:6px;background-image:radial-gradient(#222 .5px,transparent .6px);background-size:3px 3px;margin-bottom:16px}
  .mets{display:grid;grid-template-columns:repeat(4,1fr);border:1.5px solid var(--hard)}
  .met{padding:15px 14px;border-right:1px solid var(--line)}.met:last-child{border-right:0}
  .met .k{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
  .met .v{font-size:22px;font-weight:700;margin-top:7px}.met .v.bn{color:var(--orange)}
  .boxed{border:1.5px solid var(--hard)}
  table.tb{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:12.5px}
  table.tb th{text-align:left;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:#555;padding:10px 13px;border-bottom:1px solid var(--ink);background:#ececea}
  table.tb td{padding:10px 13px;border-bottom:1px solid var(--line);white-space:nowrap}
  table.tb tr:last-child td{border-bottom:0}
  .tag{font-family:var(--mono);font-size:10px;font-weight:700;padding:2px 7px;letter-spacing:.03em;text-transform:uppercase;display:inline-block;white-space:nowrap}
  .t-today{background:var(--cyan);color:#fff}.t-sched{border:1px solid var(--line);color:var(--muted)}.t-done{background:var(--green);color:#fff}
  .qin{width:100%;font-family:var(--mono);font-size:13px;background:#fff;border:1.5px solid var(--ink);border-radius:0;padding:12px 14px;color:var(--ink)}
  .qin:focus{outline:2px solid var(--ikb);outline-offset:-1px}
  .qhint{font-family:var(--mono);font-size:12px;color:var(--muted);margin-top:8px}
  .mlist{padding-left:18px;color:#333;line-height:1.65;font-size:14px}
  .mlist li{margin-bottom:8px}
  .enact{color:#333;line-height:1.65;font-size:14px;max-width:70ch}
  footer{background:#fff;border-top:1px solid var(--ink)}
  .foot{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--muted);padding:20px 28px;max-width:1060px;margin:0 auto}
  .foot a{color:var(--muted)}.flinks{display:flex;gap:14px;flex-wrap:wrap;justify-content:flex-end}
  @media(max-width:760px){.bar,.foot{padding:0 18px}.foot{padding:20px 18px}.wrap{padding:0 16px}nav{display:none}.mets{grid-template-columns:1fr 1fr}.met:nth-child(2n){border-right:0}table.tb{font-size:11px}table.tb td,table.tb th{padding:9px 9px}}
</style>

<header><div class="bar">
  <div class="mark"><span class="sq"></span><a href="/">NUMETAL</a></div>
  <nav>
    <span class="upd">App · updating</span>
    <a href="/">Studio</a>
    <a href="/fees">Fee engine</a>
    <a href="/airdrops" class="on">Airdrops</a>
    <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;↗</a>
  </nav>
</div></header>
<div class="dither"></div>

<main>
  <section class="wrap intro">
    <div class="eyebrow">Doc · Retrodrop 01 · Base · no signing</div>
    <h1>BOUNTY + PLATES retrodrop<span class="dot">.</span></h1>
    <p class="sub">500M $NUMETAL back to the real holders of the predecessor tokens — snapshotted at the Numetal launch block, paid in 5 onchain batches via Smol Disperse. No signing, no claim. If you held, it just arrives.</p>
    <div class="hstat" id="hstatus"><span class="dotp"></span><span>loading status…</span></div>
  </section>

  <div class="dither"></div>
  <section class="wrap sec">
    <div class="mets">
      <div class="met"><div class="k">Total</div><div class="v">500M</div></div>
      <div class="met"><div class="k">Per batch</div><div class="v">100M</div></div>
      <div class="met"><div class="k">Wallets</div><div class="v" id="mRec">657</div></div>
      <div class="met"><div class="k">Burn cover</div><div class="v bn">2.36×</div></div>
    </div>
  </section>

  <div class="dither"></div>
  <section class="wrap sec"><div class="sh"><span class="ix">01</span>Batch tracker</div><div class="sdot"></div>
    <div class="boxed"><table class="tb"><thead><tr><th>Batch</th><th>When</th><th>NUMETAL</th><th>Status</th><th>Tx</th></tr></thead><tbody id="tracker"><tr><td colspan="5" style="color:var(--muted)">loading…</td></tr></tbody></table></div>
    <div class="qhint">Each batch flips to a green tick with its Basescan tx once sent — verifiable onchain.</div>
  </section>

  <div class="dither"></div>
  <section class="wrap sec"><div class="sh"><span class="ix">02</span>Check your allocation</div><div class="sdot"></div>
    <input class="qin" id="q" placeholder="paste your address (0x…)" autocomplete="off" spellcheck="false" aria-label="Your wallet address" style="max-width:540px"/>
    <div class="qhint">No wallet connection — read-only lookup. Try <span id="ex" style="color:var(--ikb);cursor:pointer;text-decoration:underline">0xb1fd2b…</span></div>
    <div id="result" style="margin-top:14px;max-width:540px"></div>
  </section>

  <div class="dither"></div>
  <section class="wrap sec"><div class="sh"><span class="ix">03</span>The numbers</div><div class="sdot"></div>
    <div class="boxed" style="max-width:600px"><table class="tb">
      <thead><tr><th></th><th style="text-align:right">Bounty</th><th style="text-align:right">Plates</th></tr></thead><tbody>
      <tr><td style="color:#555">Eligible holders</td><td style="text-align:right">654</td><td style="text-align:right">17</td></tr>
      <tr><td style="color:#555">Tokens held</td><td style="text-align:right">24.29B</td><td style="text-align:right">50.27M</td></tr>
      <tr><td style="color:#555">$NUMETAL allocated</td><td style="text-align:right">499.99M</td><td style="text-align:right">14.6K</td></tr>
      <tr><td style="color:#555">Share of drop</td><td style="text-align:right">99.997%</td><td style="text-align:right">0.003%</td></tr>
    </tbody></table></div>
    <div class="qhint">Snapshot · block 46,958,289 · Jun 6 2026 (Numetal launch).</div>
  </section>

  <div class="dither"></div>
  <section class="wrap sec"><div class="sh"><span class="ix">04</span>Methodology</div><div class="sdot"></div>
    <ul class="mlist" style="max-width:70ch">
      <li>Balances reconstructed from the full onchain transfer history of both tokens up to the launch block — every token accounted for.</li>
      <li>Real people only — 10 infra/bot wallets stripped (AMM pools, Clanker fee locker, MEV bots, CoW, routers); 152 personal smart wallets (Coinbase, Safe, MetaMask) kept.</li>
      <li>Liquidity-adjusted weighting — BOUNTY valued ~71× PLATES, since PLATES had near-zero real float and volume.</li>
      <li>Net-deflationary — 1.18B $NUMETAL already burned vs 500M airdropped (2.36× coverage).</li>
    </ul>
  </section>

  <div class="dither"></div>
  <section class="wrap sec" style="padding-bottom:34px"><div class="sh"><span class="ix">05</span>How we enact it</div><div class="sdot"></div>
    <div class="enact">Pushed via <a href="https://smold.app/disperse" style="color:var(--ink);font-weight:700">Smol Disperse</a> on Base — 5 batches of 100M from the founder deployer <span style="color:var(--ikb)">0x15813f…B93c3</span>. Recipients sign nothing; the tokens simply arrive. Each batch is logged on the <a href="/fees">fee-engine report</a> tagged <span class="tag" style="background:var(--ikb);color:#fff">retrodrop&nbsp;N/5</span> — distribution, not a burn, so it never touches the burned total. Every batch is one onchain transaction, linked in the tracker above.</div>
  </section>
</main>

<div class="dither"></div>
<footer><div class="foot">
  <span>Numetal · retrodrop · Base · <a href="/fees">fee engine</a></span>
  <span class="flinks">
    <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier Gökhan</a>
    <a href="https://github.com/gokhan-vc" target="_blank" rel="noopener">GitHub</a>
    <a href="https://gokhanturhan.com" target="_blank" rel="noopener">gokhanturhan.com</a>
    <a href="/feed.xml">RSS</a>
    <a href="/sitemap.xml">Sitemap</a>
    <a href="/llms.txt">llms.txt</a>
    <a href="https://numetal.xyz/terms">Terms</a>
    <a href="https://numetal.xyz/privacy">Privacy</a>
    <a href="/cookies">Cookies</a>
  </span>
</div></footer>
`;
---
<Base title={title} description={description} canonical={canonical}>
  <Fragment set:html={bodyHtml} />
  <script src="/airdrop.js" defer is:inline></script>
</Base>
