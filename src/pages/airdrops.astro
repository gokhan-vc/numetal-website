---
export const prerender = true;
import Base from '../layouts/Base.astro';
const title = "Numetal — BOUNTY + PLATES retrodrop";
const description = "500M $NUMETAL retrodropped to the real holders of BOUNTY + PLATES, snapshotted at the Numetal launch block. Methodology, full recipient list, live batch tracker — no signing.";
const canonical = 'https://numetal.xyz/airdrops';
const bodyHtml = `<style>
  :root{--ikb:#002FA7;--bgray:#e7e7e7;--ink:#141414;--orange:#FF5A1F;--cyan:#0791a6;--green:#0F8A4C;--gold:#9a7d12;--line:#c4c4c4;--muted:#6f6f6f;
    --mono:ui-monospace,'SF Mono','SFMono-Regular',Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,'Liberation Sans',sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-font-smoothing:antialiased}
  body{background:var(--bgray);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .sheet{max-width:880px;margin:0 auto;background:#fff;border-left:1px solid var(--line);border-right:1px solid var(--line);min-height:100vh;display:flex;flex-direction:column}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  .top{display:flex;align-items:center;justify-content:space-between;padding:16px 32px 0}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.04em;font-size:17px}
  .mark a{color:var(--ink)}.mark .sq{width:13px;height:13px;background:var(--ikb)}
  nav{display:flex;gap:18px;font-size:13px;align-items:center}
  nav a{color:var(--ink)}nav a.on{color:var(--ikb);font-weight:700}nav .upd{color:var(--muted)}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);padding:6px 32px 14px}
  .stamp b{color:var(--ikb);font-weight:700}
  main{flex:1}
  .pad{padding:24px 32px}
  @keyframes pulse{0%,100%{opacity:1}50%{opacity:.25}}
  .dotp{width:7px;height:7px;border-radius:50%;background:var(--cyan);display:inline-block;animation:pulse 1.8s ease-in-out infinite}
  .intro{padding-top:30px;padding-bottom:8px;text-align:center}
  .eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);margin-bottom:12px}
  h1{font-size:32px;line-height:1.04;font-weight:700;letter-spacing:-.025em}
  h1 .dot{color:var(--ikb)}
  .sub{font-size:15px;color:#444;margin-top:12px;max-width:66ch;line-height:1.55;margin-left:auto;margin-right:auto}
  .hstat{font-family:var(--mono);font-size:12px;letter-spacing:.04em;text-transform:uppercase;color:var(--ink);margin-top:18px;display:flex;align-items:center;gap:9px;justify-content:center}
  .sh{display:flex;align-items:baseline;gap:11px;font-family:var(--mono);font-size:12px;letter-spacing:.12em;text-transform:uppercase;font-weight:700;margin-bottom:14px;justify-content:center}
  .sh .ix{color:var(--muted)}
  .mets{display:grid;grid-template-columns:repeat(4,1fr);border:1.5px solid var(--ink)}
  .met{padding:14px 14px;border-right:1px solid var(--line)}.met:last-child{border-right:0}
  .met .k{font-family:var(--mono);font-size:11px;letter-spacing:.07em;text-transform:uppercase;color:var(--muted)}
  .met .v{font-size:21px;font-weight:700;margin-top:6px}.met .v.bn{color:var(--orange)}
  .boxed{border:1.5px solid var(--ink)}
  table.tb{width:100%;border-collapse:collapse;font-family:var(--mono);font-size:12.5px}
  table.tb th{text-align:left;font-size:10px;letter-spacing:.08em;text-transform:uppercase;color:#555;padding:10px 13px;border-bottom:1px solid var(--ink);background:#eeeeec}
  table.tb td{padding:10px 13px;border-bottom:1px solid var(--line);white-space:nowrap}
  table.tb tr:last-child td{border-bottom:0}
  .tag{font-family:var(--mono);font-size:10px;font-weight:700;padding:2px 7px;letter-spacing:.03em;text-transform:uppercase;display:inline-block;white-space:nowrap}
  .t-today{background:var(--cyan);color:#fff}.t-sched{border:1px solid var(--line);color:var(--muted)}.t-done{background:var(--green);color:#fff}
  .qin{width:100%;font-family:var(--mono);font-size:13px;background:#fff;border:1.5px solid var(--ink);border-radius:0;padding:11px 14px;color:var(--ink)}
  .qin:focus{outline:2px solid var(--ikb);outline-offset:-1px}
  .qhint{font-family:var(--mono);font-size:11.5px;color:var(--muted);margin-top:8px;text-align:center}
  .mlist{padding-left:0;list-style:none;text-align:justify;text-align-last:left;-webkit-hyphens:auto;hyphens:auto;-webkit-hyphenate-limit-before:3;-webkit-hyphenate-limit-after:3;hyphenate-limit-chars:6 3 3;text-wrap:pretty;max-width:63ch;margin:0 auto;color:#333;line-height:1.5;font-size:14px}
  .mlist li{margin-bottom:8px}
  .enact{color:#333;line-height:1.5;font-size:14px;max-width:63ch;text-align:justify;text-align-last:left;-webkit-hyphens:auto;hyphens:auto;-webkit-hyphenate-limit-before:3;-webkit-hyphenate-limit-after:3;hyphenate-limit-chars:6 3 3;text-wrap:pretty;margin-left:auto;margin-right:auto}
  .ft{border-top:1px solid var(--ink);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--muted);padding:18px 32px}
  .ft a{color:var(--muted)}.flinks{display:flex;gap:13px;flex-wrap:wrap;justify-content:flex-end}
  @media(max-width:760px){.top,.stamp,.pad,.ft{padding-left:18px;padding-right:18px}nav{display:none}.mets{grid-template-columns:1fr 1fr}.met:nth-child(2n){border-right:0}table.tb{font-size:11px}table.tb td,table.tb th{padding:9px 9px}.mlist,.enact{text-align:left}}
  .social{display:inline-flex;align-items:center;gap:14px}
  .social a{display:inline-flex;color:inherit;line-height:0;text-decoration:none}
  .social a:hover{color:var(--ikb)}
  .social svg{width:17px;height:17px;fill:currentColor;display:block}
</style>

<div class="sheet">
  <div class="top">
    <div class="mark"><span class="sq"></span><a href="/">NUMETAL</a></div>
    <nav>
      <span class="upd">App · updating</span>
      <a href="/">Studio</a>
      <a href="/fees">Fee engine</a>
      <span class="upd">Docs · updating</span>
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;↗</a>
    </nav>
  </div>
  <div class="stamp">Doc · <b>Retrodrop 01</b> · Base · no signing</div>
  <div class="dither"></div>

  <main>
    <section class="pad intro">
      <div class="eyebrow">Retrodrop 01 · BOUNTY + PLATES · Base</div>
      <h1>BOUNTY + PLATES retrodrop<span class="dot">.</span></h1>
      <p class="sub">500M $NUMETAL back to the real holders of the predecessor tokens — snapshotted at the Numetal launch block, paid in 5 onchain batches via Smol Disperse. No signing, no claim. If you held, it just arrives.</p>
      <div class="hstat" id="hstatus"><span class="dotp"></span><span>loading status…</span></div>
    </section>

    <div class="dither"></div>
    <section class="pad">
      <div class="mets">
        <div class="met"><div class="k">Total</div><div class="v">500M</div></div>
        <div class="met"><div class="k">Per batch</div><div class="v">100M</div></div>
        <div class="met"><div class="k">Wallets</div><div class="v" id="mRec">657</div></div>
        <div class="met"><div class="k">Burn cover</div><div class="v bn">2.36×</div></div>
      </div>
    </section>

    <div class="dither"></div>
    <section class="pad"><div class="sh"><span class="ix">01</span>Batch tracker</div>
      <div class="boxed"><table class="tb"><thead><tr><th>Batch</th><th>When</th><th>NUMETAL</th><th>Status</th><th>Tx</th></tr></thead><tbody id="tracker"><tr><td colspan="5" style="color:var(--muted)">loading…</td></tr></tbody></table></div>
      <div class="qhint">Each batch flips to a green tick with its Basescan tx once sent — verifiable onchain.</div>
    </section>

    <div class="dither"></div>
    <section class="pad"><div class="sh"><span class="ix">02</span>Check your allocation</div>
      <input class="qin" id="q" placeholder="paste your address (0x…)" autocomplete="off" spellcheck="false" aria-label="Your wallet address" style="max-width:540px;margin:0 auto;display:block"/>
      <div class="qhint" style="text-align:center">No wallet connection — read-only lookup. Try <span id="ex" style="color:var(--ikb);cursor:pointer;text-decoration:underline">0xb1fd2b…</span></div>
      <div id="result" style="margin:14px auto 0;max-width:540px"></div>
      <div class="qhint" style="text-align:center;margin-top:13px">Full list — every address, holdings &amp; allocation: <a href="https://raw.githubusercontent.com/gokhan-vc/numetal-website/main/public/recipients.csv" target="_blank" rel="noopener" style="color:var(--ikb);text-decoration:underline">raw CSV&nbsp;↗</a> · <a href="https://github.com/gokhan-vc/numetal-website/blob/main/public/recipients.csv" target="_blank" rel="noopener" style="color:var(--ikb);text-decoration:underline">table&nbsp;view&nbsp;↗</a></div>
    </section>

    <div class="dither"></div>
    <section class="pad"><div class="sh"><span class="ix">03</span>The numbers</div>
      <div class="boxed" style="max-width:520px;margin:0 auto"><table class="tb">
        <thead><tr><th></th><th style="text-align:right">Bounty</th><th style="text-align:right">Plates</th></tr></thead><tbody>
        <tr><td style="color:#555">Eligible holders</td><td style="text-align:right">654</td><td style="text-align:right">17</td></tr>
        <tr><td style="color:#555">Tokens held</td><td style="text-align:right">24.29B</td><td style="text-align:right">50.27M</td></tr>
        <tr><td style="color:#555">$NUMETAL allocated</td><td style="text-align:right">499.99M</td><td style="text-align:right">14.6K</td></tr>
        <tr><td style="color:#555">Share of drop</td><td style="text-align:right">99.997%</td><td style="text-align:right">0.003%</td></tr>
      </tbody></table></div>
      <div class="qhint" style="text-align:center">Snapshot · block 46,958,289 · Jun 6 2026 (Numetal launch).</div>
    </section>

    <div class="dither"></div>
    <section class="pad"><div class="sh"><span class="ix">04</span>Methodology</div>
      <ul class="mlist">
        <li>Balances reconstructed from the full onchain transfer history of both tokens up to the launch block — every token accounted for.</li>
        <li>Real people only — 10 infra/bot wallets stripped (AMM pools, Clanker fee locker, MEV bots, CoW, routers); 152 personal smart wallets (Coinbase, Safe, Meta&shy;Mask) kept.</li>
        <li>Liquidity-adjusted weighting — BOUNTY valued ~71× PLATES, since PLATES had near-zero real float and volume.</li>
        <li>Net-deflationary — 1.18B $NUMETAL already burned vs 500M air&shy;dropped (2.36× coverage).</li>
      </ul>
    </section>

    <div class="dither"></div>
    <section class="pad" style="padding-bottom:30px"><div class="sh"><span class="ix">05</span>How we enact it</div>
      <div class="enact">Pushed via <a href="https://smold.app/disperse" style="color:var(--ink);font-weight:700">Smol Disperse</a> on Base — 5 batches of 100M from the founder deployer <span style="color:var(--ikb)">0x15813f…B93c3</span>. Recipients sign nothing; the tokens simply arrive. Each batch is logged on the <a href="/fees">fee-engine report</a> tagged <span class="tag" style="background:var(--ikb);color:#fff">retrodrop&nbsp;N/5</span> — distribution, not a burn, so it never touches the burned total. Every batch is one onchain transaction, linked in the tracker above.</div>
    </section>
  </main>

  <div class="dither"></div>
  <footer class="ft">
    <span>Numetal · an Atelier Gökhan studio · on Base</span>
    <span class="social"><a href="https://t.me/numetalxyz" target="_blank" rel="noopener" aria-label="Telegram"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg></a><a href="https://discord.gg/MC4DYumPMz" target="_blank" rel="noopener" aria-label="Discord"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 0 0-4.8851-1.5152.0741.0741 0 0 0-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 0 0-.0785-.037 19.7363 19.7363 0 0 0-4.8852 1.515.0699.0699 0 0 0-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 0 0 .0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 0 0 .0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 0 0-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 0 1-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 0 1 .0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 0 1 .0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 0 1-.0066.1276 12.2986 12.2986 0 0 1-1.873.8914.0766.0766 0 0 0-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 0 0 .0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 0 0 .0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 0 0-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg></a><a href="https://x.com/numetalxyz" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a></span>
      <span class="flinks">
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier Gökhan</a>
      <a href="https://github.com/gokhan-vc" target="_blank" rel="noopener">GitHub</a>
      <a href="https://gokhanturhan.com" target="_blank" rel="noopener">gokhanturhan.com</a>
      <a href="/feed.xml">RSS</a>
      <a href="/sitemap.xml">Sitemap</a>
      <a href="/llms.txt">llms.txt</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
      <a href="/cookies">Cookies</a>
    </span>
  </footer>
</div>
`;
---
<Base title={title} description={description} canonical={canonical}>
  <Fragment set:html={bodyHtml} />
  <script src="/airdrop.js" defer is:inline></script>
</Base>
