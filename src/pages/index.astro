---
import Base from '../layouts/Base.astro';
export const prerender = true;
const title = "Numetal — agent accelerator studio";
const description = "Numetal is an agent accelerator studio under Atelier Gökhan — building and backing autonomous agents across onchain, compute, artistic & cultural markets, and frontier-lab model toolkits. Chain-agnostic: Base, Ethereum, Solana, Hyperliquid, XRP Ledger.";
const canonical = "https://numetal.xyz/";
const ogImage = "https://numetal.xyz/og.png";
const jsonLd = `{"@context":"https://schema.org","@graph":[
{"@type":"Organization","@id":"https://numetal.xyz/#organization","name":"Numetal","alternateName":"$NUMETAL","url":"https://numetal.xyz/","description":"Numetal is an agent accelerator studio under Atelier Gökhan — building and backing autonomous agents across onchain, compute, artistic & cultural markets, and frontier-lab model toolkits. Chain-agnostic: home on Base, working across Ethereum, Solana, Hyperliquid, and the XRP Ledger.","slogan":"We ship machines that ship themselves.","parentOrganization":{"@type":"Organization","name":"Atelier Gökhan","url":"https://gokhan.vc"},"founder":{"@type":"Person","name":"Gökhan Turhan","url":"https://gokhanturhan.com"},"knowsAbout":["Autonomous AI agents","Onchain agent economy","x402 machine-to-machine payments","Base","Ethereum","Solana","Hyperliquid","XRP Ledger","Buyback and burn fee distribution"],"sameAs":["https://gokhan.vc","https://github.com/gokhan-vc","https://gokhanturhan.com"]},
{"@type":"WebSite","@id":"https://numetal.xyz/#website","url":"https://numetal.xyz/","name":"Numetal","description":"Agent accelerator studio under Atelier Gökhan — autonomous agents across onchain, compute, artistic & cultural markets, and frontier-lab model toolkits.","inLanguage":"en","publisher":{"@id":"https://numetal.xyz/#organization"}}
]}`;
const bodyHtml = `<style>
  :root{--ikb:#002FA7;--paper:#FAFAF8;--ink:#141414;--orange:#FF5A1F;--cyan:#0791a6;--gold:#9a7d12;--line:#cfcfcf;--hard:#8c8c8c;--muted:#7c7c7c;
    --mono:ui-monospace,'SF Mono','SFMono-Regular',Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,'Liberation Sans',sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;scroll-behavior:smooth}
  body{background:var(--paper);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5;min-height:100vh;display:flex;flex-direction:column}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .wrap{width:100%;max-width:1060px;margin:0 auto;padding:0 28px}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  header{border-bottom:1px solid var(--ink);position:sticky;top:0;background:var(--paper);z-index:5}
  .bar{display:flex;align-items:center;justify-content:space-between;height:54px;max-width:1060px;margin:0 auto;padding:0 28px}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.04em;font-size:17px}
  .mark .sq{width:13px;height:13px;background:var(--ikb)}
  nav{display:flex;gap:20px;font-size:13px;align-items:center}
  nav a{color:var(--ink)}nav .upd{color:var(--muted)}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.08em;color:var(--muted);text-transform:uppercase}
  main{flex:1}
  .hero{padding:64px 0 48px}
  .eyebrow{font-family:var(--mono);font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin-bottom:22px}
  h1{font-size:clamp(40px,7vw,74px);line-height:1.0;font-weight:700;letter-spacing:-.03em}
  h1 .dot{color:var(--ikb)}
  .lede{font-size:18px;line-height:1.55;color:#333;max-width:64ch;margin-top:24px}
  .cta{display:flex;gap:14px;align-items:center;margin-top:34px;flex-wrap:wrap}
  .btn{display:inline-flex;align-items:center;gap:8px;background:var(--ikb);color:#fff;padding:11px 20px;font-weight:700;font-size:14px;border:1.5px solid var(--ink);box-shadow:2px 2px 0 rgba(0,0,0,.5);transition:filter .1s,transform .05s,box-shadow .05s}
  .btn:hover{filter:brightness(1.08);text-decoration:none}
  .btn:active{transform:translate(2px,2px);box-shadow:0 0 0 rgba(0,0,0,0)}
  .btn.dis{background:#ededed;color:var(--muted);border-color:var(--hard);box-shadow:none;cursor:default}
  .btn.dis:hover{filter:none}
  .sec{padding:42px 0}
  .sh{display:flex;align-items:baseline;gap:11px;font-size:13px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;margin-bottom:8px;font-family:var(--mono)}
  .sh .ix{color:var(--muted)}
  .sdot{height:6px;background-image:radial-gradient(#222 .5px,transparent .6px);background-size:3px 3px;margin-bottom:18px}
  .grid4{display:grid;grid-template-columns:repeat(2,1fr);border:1.5px solid var(--hard)}
  .cell{padding:22px 20px;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}
  .cell:nth-child(2n){border-right:0}
  .cell:nth-last-child(-n+2){border-bottom:0}
  .cell .k{font-family:var(--mono);font-size:13px;letter-spacing:.04em;text-transform:uppercase;font-weight:700;margin-bottom:9px}
  .cell .k.o{color:var(--orange)}.cell .k.b{color:var(--ikb)}.cell .k.c{color:var(--cyan)}.cell .k.g{color:var(--gold)}
  .cell p{font-size:14px;color:#444;line-height:1.55}
  .chains{display:flex;flex-wrap:wrap;border:1.5px solid var(--hard)}
  .chain{flex:1 1 18%;min-width:120px;padding:16px 16px;border-right:1px solid var(--line)}
  .chain:last-child{border-right:0}
  .chain .cn{font-weight:700;font-size:15px}
  .chain .cr{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);margin-top:6px}
  .chain.hub{background:var(--ikb);color:#fff}.chain.hub .cr{color:rgba(255,255,255,.72)}
  .leg{display:flex;align-items:center;gap:16px;flex-wrap:wrap;font-family:var(--mono);font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:14px}
  .leg .lg{display:flex;align-items:center;gap:7px}.leg .d{width:9px;height:9px}
  .d-team{background:var(--orange)}.d-trez{background:var(--ikb)}.d-burn{background:var(--ink)}
  .side{margin-top:16px}
  .side-head{display:flex;justify-content:space-between;align-items:baseline;gap:12px;margin-bottom:8px;font-family:var(--mono);font-size:12px}
  .side-head .nm{font-weight:700;text-transform:uppercase;letter-spacing:.05em}.side-head .tot{color:var(--muted)}
  .barx{display:flex;height:34px;border:1.5px solid var(--ink)}
  .seg{display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;color:#fff;white-space:nowrap;overflow:hidden;border-right:1px solid rgba(255,255,255,.35)}
  .seg:last-child{border-right:0}
  .s-team{background:var(--orange)}.s-trez{background:var(--ikb)}.s-burn{background:var(--ink);color:var(--paper)}
  .note{font-size:14px;color:#444;margin-top:18px;max-width:70ch}
  footer{background:#fff;border-top:1px solid var(--ink)}
  .foot{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--muted);padding:20px 28px;max-width:1060px;margin:0 auto}
  .foot a{color:var(--muted)}
  .flinks{display:flex;gap:14px;flex-wrap:wrap;justify-content:flex-end}
  @media(max-width:760px){.bar,.foot{padding-left:18px;padding-right:18px}.wrap{padding:0 18px}nav{display:none}.grid4{grid-template-columns:1fr}.cell{border-right:0}.cell:nth-last-child(-n+2){border-bottom:1px solid var(--line)}.cell:last-child{border-bottom:0}.chain{flex:1 1 100%;border-right:0;border-bottom:1px solid var(--line)}.chain:last-child{border-bottom:0}}
</style>

<header><div class="bar">
  <div class="mark"><span class="sq"></span>NUMETAL</div>
  <nav>
    <span class="upd">App · updating</span>
    <a href="https://numetal.xyz/fees">Fee engine</a>
    <a href="https://numetal.xyz/airdrops">Airdrops</a>
    <span class="upd">Docs · updating</span>
    <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;↗</a>
  </nav>
</div></header>
<div class="dither"></div>

<main>
  <section class="wrap hero">
    <div class="eyebrow">Doc · Studio · Base · an <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;Gökhan</a> studio</div>
    <h1>We ship machines that ship themselves<span class="dot">.</span></h1>
    <p class="lede">An accelerator that builds and backs autonomous agents across four markets — onchain, compute, artistic &amp; culture, and frontier-lab model toolkits. Chain-agnostic by design: home on Base, working across Ethereum, Solana, Hyperliquid, and the XRP Ledger. A few agents are already in the queue.</p>
    <div class="cta">
      <span class="btn dis">App — updating</span>
      <span class="btn dis">Docs — updating</span>
      <a class="btn" href="https://numetal.xyz/fees">Fee engine →</a>
    </div>
  </section>

  <div class="dither"></div>
  <section class="wrap sec">
    <div class="sh"><span class="ix">01</span>What we ship — agents across four markets</div>
    <div class="sdot"></div>
    <div class="grid4">
      <div class="cell"><div class="k o">Onchain</div><p>Agents that live in the onchain economy — intelligence, trading, and x402 services across the Base / Bankr agent economy and beyond. MOAT, a Bankr-native intelligence agent, is first off the line.</p></div>
      <div class="cell"><div class="k b">Compute</div><p>Agents that buy and sell compute and inference — paying for what they consume and charging for what they serve, settled machine-to-machine over x402.</p></div>
      <div class="cell"><div class="k g">Artistic &amp; cultural</div><p>Agents working in art, culture, and hyperstition — generative, speculative, accelerationist. Markets where taste and myth compound, not just liquidity.</p></div>
      <div class="cell"><div class="k c">Frontier-lab toolkits</div><p>Runtimes, skills, and harnesses built on frontier-lab models — the tooling that turns raw models into autonomous operators that earn.</p></div>
    </div>
  </section>

  <div class="dither"></div>
  <section class="wrap sec">
    <div class="sh"><span class="ix">02</span>Chain-agnostic — home on Base, working everywhere</div>
    <div class="sdot"></div>
    <div class="chains">
      <div class="chain hub"><div class="cn">Base</div><div class="cr">Hub · home</div></div>
      <div class="chain"><div class="cn">Ethereum</div><div class="cr">Mainnet</div></div>
      <div class="chain"><div class="cn">Solana</div><div class="cr">High-throughput</div></div>
      <div class="chain"><div class="cn">Hyperliquid</div><div class="cr">Onchain perps</div></div>
      <div class="chain"><div class="cn">XRP Ledger</div><div class="cr">x402 · RLUSD</div></div>
    </div>
    <p class="note">Base is home — where the token, treasury, and settlement live. Our agents reach into demand wherever it is and bring value back, settling over x402 and native USDC rails. New chains attach the moment an agent has a reason to be there.</p>
  </section>

  <div class="dither"></div>
  <section class="wrap sec">
    <div class="sh"><span class="ix">03</span>$NUMETAL fee distribution policy</div>
    <div class="sdot"></div>
    <div class="leg"><span class="lg"><span class="d d-team"></span>team</span><span class="lg"><span class="d d-trez"></span>treasury</span><span class="lg"><span class="d d-burn"></span>burn (incl. buyback)</span></div>
    <div class="side">
      <div class="side-head"><span class="nm">WETH side</span><span class="tot">100% of claimed WETH</span></div>
      <div class="barx"><span class="seg s-team" style="flex:80 0 0">80% team</span><span class="seg s-trez" style="flex:10 0 0">10%</span><span class="seg s-burn" style="flex:10 0 0">10%</span></div>
    </div>
    <div class="side">
      <div class="side-head"><span class="nm">$NUMETAL side</span><span class="tot">100% of claimed $NUMETAL</span></div>
      <div class="barx"><span class="seg s-team" style="flex:40 0 0">40% team</span><span class="seg s-trez" style="flex:30 0 0">30% treasury</span><span class="seg s-burn" style="flex:30 0 0">30% burn</span></div>
    </div>
    <p class="note">Every creator-fee claim splits to team, treasury, and burn — executed onchain. Buyback &amp; burn feeds value back to the community. Watch it live on the <a href="https://numetal.xyz/fees">fee engine →</a></p>
  </section>
</main>

<div class="dither"></div>
<footer><div class="foot">
  <span>Numetal · an <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;Gökhan</a> studio · agents across onchain, compute &amp; culture</span>
  <span class="flinks">
    <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier Gökhan</a>
    <a href="https://github.com/gokhan-vc" target="_blank" rel="noopener">GitHub</a>
    <a href="https://gokhanturhan.com" target="_blank" rel="noopener">gokhanturhan.com</a>
    <a href="/feed.xml">RSS</a>
    <a href="/sitemap.xml">Sitemap</a>
    <a href="/llms.txt">llms.txt</a>
    <a href="https://numetal.xyz/terms">Terms</a>
    <a href="https://numetal.xyz/privacy">Privacy</a>
    <a href="/cookies">Cookies</a>
  </span>
</div></footer>
`;
---
<Base title={title} description={description} canonical={canonical} ogImage={ogImage} jsonLd={jsonLd}>
  <Fragment set:html={bodyHtml} />
</Base>
