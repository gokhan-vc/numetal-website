---
import Base from '../layouts/Base.astro';
export const prerender = true;
const title = "Numetal Labs — agent accelerator studio";
const description = "Numetal is an agent accelerator studio under Atelier Gökhan — building and backing autonomous agents across onchain, compute, artistic & cultural markets, and frontier-lab model toolkits. Chain-agnostic: Base, Ethereum, Solana, Hyperliquid, XRP Ledger.";
const canonical = "https://numetal.xyz/";
const ogImage = "https://numetal.xyz/og.png";
const jsonLd = `{"@context":"https://schema.org","@graph":[
{"@type":"Organization","@id":"https://numetal.xyz/#organization","name":"Numetal","alternateName":"$NUMETAL","url":"https://numetal.xyz/","description":"Numetal is an agent accelerator studio under Atelier Gökhan — building and backing autonomous agents across onchain, compute, artistic & cultural markets, and frontier-lab model toolkits. Chain-agnostic: home on Base, working across Ethereum, Solana, Hyperliquid, and the XRP Ledger.","slogan":"We ship machines that ship themselves.","parentOrganization":{"@type":"Organization","name":"Atelier Gökhan","url":"https://gokhan.vc"},"founder":{"@type":"Person","name":"Gökhan Turhan","url":"https://gokhanturhan.com"},"sameAs":["https://gokhan.vc","https://github.com/gokhan-vc","https://gokhanturhan.com"]},
{"@type":"WebSite","@id":"https://numetal.xyz/#website","url":"https://numetal.xyz/","name":"Numetal","publisher":{"@id":"https://numetal.xyz/#organization"}}
]}`;
const bodyHtml = `<style>
  :root{--ikb:#002FA7;--ink:#141414;--orange:#FF5A1F;--cyan:#0791a6;--gold:#9a7d12;--line:#cdcdcd;--hard:#8c8c8c;--mut:#7c7c7c;--bgray:#e7e7e7;
    --mono:ui-monospace,'SF Mono','SFMono-Regular',Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,'Liberation Sans',sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-font-smoothing:antialiased}
  body{background:var(--bgray);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .sheet{max-width:880px;margin:0 auto;background:#fff;border-left:1px solid #c4c4c4;border-right:1px solid #c4c4c4;min-height:100vh;display:flex;flex-direction:column}
  .top{display:flex;justify-content:space-between;align-items:center;gap:14px;padding:18px 32px 14px;position:sticky;top:29px;z-index:190;background:#fff;border-bottom:1px solid var(--line)}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.03em;font-size:16px}
  .mark .sq{width:12px;height:12px;background:var(--ikb)}
  nav{display:flex;gap:18px;font-size:13px;align-items:center}nav a{color:var(--ink)}nav .upd{color:var(--mut)}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--mut);padding:0 32px 14px}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  main{flex:1}
  .grid{display:grid;grid-template-columns:1.34fr 1fr;gap:30px;padding:30px 32px}
  h1{font-size:33px;line-height:1.05;font-weight:700;letter-spacing:-.02em}
  h1 .dot{color:var(--ikb)}
  .lead{font-size:15px;color:#2b2b2b;margin-top:15px;max-width:52ch;line-height:1.55}
  .def{border-left:3px solid var(--ikb);padding:3px 0 3px 16px;margin:22px 0;font-style:italic;color:#262626;line-height:1.5;max-width:50ch}
  .def b{font-weight:700;font-style:italic;color:var(--ink)}
  .cta{display:flex;gap:13px;align-items:center;margin-top:24px;flex-wrap:wrap}
  .btn{display:inline-flex;align-items:center;gap:8px;background:var(--ikb);color:#fff;border:1.5px solid var(--ink);font-weight:700;font-size:14px;padding:9px 16px;box-shadow:2px 2px 0 rgba(0,0,0,.5);transition:filter .1s,transform .05s,box-shadow .05s}
  .btn:hover{filter:brightness(1.1);text-decoration:none}.btn:active{transform:translate(2px,2px);box-shadow:0 0 0}
  .btn.dis{background:#ededed;color:var(--mut);border-color:var(--hard);box-shadow:none;cursor:default}.btn.dis:hover{filter:none}
  .btn.app{background:#e10600;border-color:var(--ink)}.btn.app .bh{color:#fff}
  .idxh{font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;margin-bottom:8px}
  .idx{border:1.5px solid var(--hard)}
  .ix{display:block;padding:10px 13px;border-bottom:1px solid var(--line)}
  .ix:last-child{border-bottom:0}.ix:hover{background:#eaf0fb}
  .ixr{display:flex;justify-content:space-between;align-items:baseline;gap:10px}
  .ix .k{font-weight:700;white-space:nowrap}.ix .d{display:block;font-weight:400;color:#5a5a5a;font-size:13px;margin-top:1px}.ix .v{font-family:var(--mono);font-size:12px;color:#6b6b6b;white-space:nowrap}.ix:hover .v{color:var(--ikb)}
  .sec{padding:26px 32px}
  .sh{display:flex;align-items:baseline;gap:10px;font-family:var(--mono);font-size:12px;letter-spacing:.1em;text-transform:uppercase;font-weight:700;margin-bottom:8px}.sh .ix0{color:var(--mut)}
  .sdot{height:6px;background-image:radial-gradient(#222 .5px,transparent .6px);background-size:3px 3px;margin-bottom:16px}
  .grid4{display:grid;grid-template-columns:repeat(2,1fr);border:1.5px solid var(--hard)}
  .cell{padding:18px 18px;border-right:1px solid var(--line);border-bottom:1px solid var(--line)}
  .cell:nth-child(2n){border-right:0}.cell:nth-last-child(-n+2){border-bottom:0}
  .cell .k{font-family:var(--mono);font-size:12px;letter-spacing:.04em;text-transform:uppercase;font-weight:700;margin-bottom:8px}
  .cell .k.o{color:var(--orange)}.cell .k.b{color:var(--ikb)}.cell .k.c{color:var(--cyan)}.cell .k.g{color:var(--gold)}
  .cell p{font-size:13.5px;color:#444;line-height:1.5}
  .chains{display:flex;flex-wrap:wrap;border:1.5px solid var(--hard)}
  .chain{flex:1 1 18%;min-width:118px;padding:14px 15px;border-right:1px solid var(--line)}.chain:last-child{border-right:0}
  .chain .cn{font-weight:700;font-size:15px}.chain .cr{font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--mut);margin-top:5px}
  .chain.hub{background:var(--ikb);color:#fff}.chain.hub .cr{color:rgba(255,255,255,.72)}
  .note{font-size:13.5px;color:#444;margin-top:14px;max-width:74ch;line-height:1.55}
  .leg{display:flex;gap:15px;flex-wrap:wrap;font-family:var(--mono);font-size:10px;text-transform:uppercase;letter-spacing:.05em;color:var(--mut);margin-bottom:12px}
  .leg .lg{display:flex;align-items:center;gap:6px}.leg .d{width:9px;height:9px}.d-team{background:var(--orange)}.d-trez{background:var(--ikb)}.d-burn{background:var(--ink)}
  .side{margin-top:14px}
  .side-head{display:flex;justify-content:space-between;align-items:baseline;font-family:var(--mono);font-size:11px;text-transform:uppercase;letter-spacing:.04em;margin-bottom:7px}.side-head .nm{font-weight:700}.side-head .tot{color:var(--mut)}
  .barx{display:flex;height:30px;border:1.5px solid var(--ink)}
  .seg{display:flex;align-items:center;justify-content:center;font-family:var(--mono);font-size:11px;color:#fff;white-space:nowrap;overflow:hidden;border-right:1px solid rgba(255,255,255,.4)}.seg:last-child{border-right:0}
  .s-team{background:var(--orange)}.s-trez{background:var(--ikb)}.s-burn{background:var(--ink)}
  .ft{display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--mut);padding:18px 32px}.ft a{color:var(--mut)}.flinks{display:flex;gap:13px;flex-wrap:wrap;justify-content:flex-end}
  @media(max-width:740px){.top,.stamp,.sec,.ft{padding-left:18px;padding-right:18px}.grid{grid-template-columns:1fr;gap:26px;padding:26px 18px}h1{font-size:27px}nav{display:none}.grid4{grid-template-columns:1fr}.cell{border-right:0}.cell:nth-last-child(-n+2){border-bottom:1px solid var(--line)}.cell:last-child{border-bottom:0}.chain{flex:1 1 100%;border-right:0;border-bottom:1px solid var(--line)}.chain:last-child{border-bottom:0}}
  .social{display:inline-flex;align-items:center;gap:14px}
  .social a{display:inline-flex;color:inherit;line-height:0;text-decoration:none}
  .social a:hover{color:var(--ikb)}
  .social svg{width:17px;height:17px;fill:currentColor;display:block}
  .commrow{display:flex;align-items:center;gap:13px;margin-top:16px}
  .commlab{font-family:var(--mono);font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--mut)}
</style>

<div class="sheet">
  <div class="top">
    <div class="mark"><span class="sq"></span>NUMETAL LABS</div>
    <nav>
      <a href="https://ishtar.numetal.xyz" target="_blank" rel="noopener">Use Ishtar&nbsp;♥</a>
      <a href="/blog">Blog</a>
      <a href="/fees">Fee engine</a>
      <a href="/airdrops">Airdrops</a>
      <span class="upd">Docs · updating</span>
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;↗</a>
    </nav>
  </div>
  <div class="stamp">Doc · Studio · Base · an <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier Gökhan</a> studio</div>
  <div class="dither"></div>

  <main>
    <div class="grid">
      <section>
        <h1>We ship machines that ship themselves<span class="dot">.</span></h1>
        <p class="lead">An accelerator that builds and backs autonomous agents across four markets — onchain, compute, artistic &amp; culture, and frontier-lab model toolkits.</p>
        <div class="def"><b>Numetal</b> — an agent accelerator studio: autonomous agents across onchain, compute, artistic &amp; cultural markets and frontier-lab toolkits. Chain-agnostic, home on Base.</div>
        <p class="lead">A few agents are already in the queue. The token, treasury, and settlement live on Base; the agents reach demand wherever it is and bring value back.</p>
        <div class="cta">
          <a class="btn app" href="https://ishtar.numetal.xyz" target="_blank" rel="noopener">USE ISHTAR <span class="bh">♥</span></a>
          <a class="btn" href="/fees">Fee engine →</a>
          <span class="btn dis">Docs — updating</span>
        </div>
      </section>
      <section>
        <div class="idxh">Index</div>
        <div class="idx">
          <a class="ix" href="https://ishtar.numetal.xyz" target="_blank" rel="noopener"><span class="ixr"><span class="k" style="color:#e10600">Ishtar ♥</span><span class="v" style="color:#e10600">ishtar.numetal.xyz →</span></span><span class="d">agentic dating · live</span></a>
          <a class="ix" href="/fees"><span class="ixr"><span class="k">Fee engine</span><span class="v">/fees →</span></span><span class="d">live burns &amp; buybacks</span></a>
          <a class="ix" href="https://gokhan.vc" target="_blank" rel="noopener"><span class="ixr"><span class="k">Atelier Gökhan</span><span class="v">gokhan.vc →</span></span><span class="d">the studio</span></a>
          <a class="ix" href="https://gokhanturhan.com" target="_blank" rel="noopener"><span class="ixr"><span class="k">Gökhan Turhan</span><span class="v">gokhanturhan.com →</span></span><span class="d">the founder</span></a>
          <a class="ix" href="https://dexscreener.com/base/0xf0ba727d596861455b31d6e444ed3ee41c77709a27f7d787ccf609f6c34dbbd8" target="_blank" rel="noopener"><span class="ixr"><span class="k">$NUMETAL</span><span class="v">0x57ED…CFbA3 →</span></span><span class="d">token on Base</span></a>
        </div>
        <div class="commrow"><span class="commlab">Community</span><span class="social"><a href="https://t.me/numetalxyz" target="_blank" rel="noopener" aria-label="Telegram"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg></a><a href="https://discord.gg/MC4DYumPMz" target="_blank" rel="noopener" aria-label="Discord"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.317 4.3698a19.7913 19.7913 0 0 0-4.8851-1.5152.0741.0741 0 0 0-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 0 0-.0785-.037 19.7363 19.7363 0 0 0-4.8852 1.515.0699.0699 0 0 0-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 0 0 .0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 0 0 .0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 0 0-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 0 1-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 0 1 .0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 0 1 .0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 0 1-.0066.1276 12.2986 12.2986 0 0 1-1.873.8914.0766.0766 0 0 0-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 0 0 .0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 0 0 .0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 0 0-.0312-.0286zM8.02 15