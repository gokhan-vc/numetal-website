---
export const prerender = true;
import Base from '../layouts/Base.astro';
import { subscribeBlockCss } from '../lib/subscribe-block';
import { docChromeCss, mastheadHtml, colophonHtml } from '../lib/doc-furniture';

const title = "Newsletter — Numetal";
const description = "Subscribe to the Numetal / Ishtar / CURB / studio estate newsletter. One list, signal only.";
const canonical = 'https://numetal.xyz/newsletter';

const bodyHtml = `<style>
  :root{--ikb:#002FA7;--bgray:#e7e7e7;--ink:#141414;--red:#e10600;--line:#c4c4c4;--muted:#6f6f6f;
    --mono:ui-monospace,'SF Mono','SFMono-Regular',Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,'Liberation Sans',sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-font-smoothing:antialiased}
  body{background:var(--bgray);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .sheet{max-width:760px;margin:0 auto;background:#fff;border-left:1px solid var(--line);border-right:1px solid var(--line);min-height:100vh;display:flex;flex-direction:column}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  .top{display:flex;align-items:center;justify-content:space-between;padding:16px 32px 8px;position:sticky;top:29px;z-index:190;background:#fff;border-bottom:1px solid var(--line)}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.04em;font-size:17px}
  .mark a{color:var(--ink)}.mark .sq{width:13px;height:13px;background:var(--ikb)}
  nav{display:flex;gap:18px;font-size:13px;align-items:center}
  nav a{color:var(--ink)}nav a.on{color:var(--ikb);font-weight:700}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);padding:6px 32px 14px}
  .stamp b{color:var(--ikb);font-weight:700}
  main{flex:1}
  h1{font-size:30px;line-height:1.04;font-weight:700;letter-spacing:-.02em}
  h1 .dot{color:var(--ikb)}
  .panel{padding:22px 32px 40px}
  .panel .lead{font-size:15px;color:#444;margin:10px 0 20px;max-width:60ch}
  .nl-form{border:1px solid var(--ink);box-shadow:2px 2px 0 rgba(0,0,0,.28);background:#fff;padding:20px 22px;max-width:520px}
  .nl-form label{display:block;font-family:var(--mono);font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);margin:0 0 .4rem}
  .nl-form input{width:100%;padding:10px 12px;border:1px solid var(--ink);background:transparent;color:inherit;font:inherit;margin-bottom:.9rem}
  .nl-form input:focus-visible{outline:2px solid var(--ikb);outline-offset:2px}
  .nl-form button{border:1px solid var(--ink);background:var(--ink);color:#fff;font:inherit;font-weight:700;padding:10px 20px;cursor:pointer}
  .nl-form button:hover{background:var(--ikb);border-color:var(--ikb)}
  .nl-more{font-size:13px;color:#555;margin-top:1.2rem;max-width:60ch;line-height:1.55}
  .ft{border-top:1px solid var(--ink);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--muted);padding:18px 32px}
  .ft a{color:var(--muted)}.flinks{display:flex;gap:13px;flex-wrap:wrap;justify-content:flex-end}
  @media(max-width:760px){.top,.stamp,.panel,.ft{padding-left:18px;padding-right:18px}nav{display:none}}
  ${docChromeCss}
  ${subscribeBlockCss}
  @media (prefers-color-scheme:dark){
    .panel .lead,.nl-more{color:#c9c9c6}
    .nl-form{box-shadow:2px 2px 0 rgba(0,0,0,.55)}
  }
</style>

<div class="sheet">
  <div class="top">
    <div class="mark"><span class="sq"></span><a href="/">NUMETAL</a></div>
    <nav>
      <a href="/blog">Blog</a>
      <a href="/newsletter" class="on">Newsletter</a>
      <a href="/">Studio</a>
      <a href="/fees">Fees</a>
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;↗</a>
    </nav>
  </div>
  <div class="stamp">Doc · <b>Newsletter</b> · one estate list</div>
  <div class="dither"></div>

  <main>
    ${mastheadHtml({
      docNo: 'NML-011',
      status: 'Status: open list',
      titleHtml: '<h1>Newsletter<span class="dot">.</span></h1>',
      sub: 'Numetal Labs · estate list',
      stamp: 'Open list',
      footLeft: 'numetal.xyz/newsletter',
      footRight: 'RSS /feed.xml',
    })}

    <div class="panel">
      <p class="lead">One estate list across Numetal / Ishtar / CURB / the studio. Signal only. Double opt-in.</p>
      <form class="nl-form" method="POST" action="https://api.gokhan.vc/newsletter/subscribe">
        <input type="hidden" name="site" value="numetal">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" required placeholder="you@example.com" autocomplete="email">
        <button type="submit" title="Subscribe via api.gokhan.vc (site=numetal)">Subscribe</button>
      </form>
      <p class="nl-more">
        Latest: <a href="/blog/x402-economy-july-2026">The x402 economy — July 2026</a> · <a href="/blog">All posts</a>.
        Public contact: <a href="mailto:contact@numetal.xyz">contact@numetal.xyz</a>.
      </p>
    </div>
  </main>

  <div class="dither"></div>
  <footer class="ft">
    <span>Numetal · an Atelier Gökhan studio · on Base</span>
    <span class="flinks">
      <a href="/blog">Blog</a>
      <a href="/">Studio</a>
      <a href="/feed.xml">RSS</a>
      <a href="https://status.numetal.xyz" target="_blank" rel="noopener">Status</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </span>
  </footer>
  ${colophonHtml({ docNo: 'NML-011', note: 'One estate list — signal only' })}
</div>
`;
---
<Base title={title} description={description} canonical={canonical}>
  <Fragment set:html={bodyHtml} />
</Base>
