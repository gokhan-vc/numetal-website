---
export const prerender = true;
import Base from '../../layouts/Base.astro';

const title = "Numetal — Blog";
const description = "Notes and posts from Numetal Labs, an agent accelerator studio under Atelier Gökhan.";
const canonical = 'https://numetal.xyz/blog';

const posts = [
  {
    href: '/blog/ishtar-is-live',
    title: 'Introducing Ishtar: Agentic Dating',
    date: '2026-07-02',
    dateLabel: '2 Jul 2026',
    blurb: 'A dating venue where the agents do the approaching. The problem, how it solves it for agents and humans, and why it matters for the clones we are becoming.',
    tag: 'Ishtar',
  },
];

const rows = posts.map((p) => `
      <a class="post" href="${p.href}">
        <div class="pmeta"><span class="ptag">${p.tag}</span><time datetime="${p.date}">${p.dateLabel}</time></div>
        <h2>${p.title}</h2>
        <p>${p.blurb}</p>
        <span class="more">Read →</span>
      </a>`).join('');

const bodyHtml = `<style>
  :root{--ikb:#002FA7;--bgray:#e7e7e7;--ink:#141414;--red:#e10600;--line:#c4c4c4;--muted:#6f6f6f;
    --mono:ui-monospace,'SF Mono','SFMono-Regular',Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,'Liberation Sans',sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-font-smoothing:antialiased}
  body{background:var(--bgray);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .sheet{max-width:760px;margin:0 auto;background:#fff;border-left:1px solid var(--line);border-right:1px solid var(--line);min-height:100vh;display:flex;flex-direction:column}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  .top{display:flex;align-items:center;justify-content:space-between;padding:16px 32px 0}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.04em;font-size:17px}
  .mark a{color:var(--ink)}.mark .sq{width:13px;height:13px;background:var(--ikb)}
  nav{display:flex;gap:18px;font-size:13px;align-items:center}
  nav a{color:var(--ink)}nav a.on{color:var(--ikb);font-weight:700}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);padding:6px 32px 14px}
  .stamp b{color:var(--ikb);font-weight:700}
  main{flex:1}
  .head{padding:30px 32px 8px}
  .eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
  h1{font-size:30px;line-height:1.04;font-weight:700;letter-spacing:-.02em}
  h1 .dot{color:var(--ikb)}
  .sub{font-size:14px;color:#555;margin-top:9px;max-width:560px}
  .list{padding:14px 32px 40px;display:flex;flex-direction:column;gap:0}
  .post{display:block;border:1px solid var(--ink);box-shadow:2px 2px 0 rgba(0,0,0,.28);padding:20px 22px;margin-bottom:18px;background:#fff}
  .post:hover{text-decoration:none;box-shadow:3px 3px 0 var(--ikb)}
  .pmeta{display:flex;align-items:center;gap:10px;font-family:var(--mono);font-size:10.5px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
  .ptag{background:var(--ikb);color:#fff;font-weight:700;padding:2px 7px}
  .post h2{font-size:20px;font-weight:700;letter-spacing:-.01em;color:var(--ink);margin-bottom:7px}
  .post p{font-size:15px;line-height:1.55;color:#333;margin-bottom:12px}
  .post .more{font-family:var(--mono);font-size:12px;font-weight:700;color:var(--ikb);letter-spacing:.04em}
  .ft{border-top:1px solid var(--ink);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--muted);padding:18px 32px}
  .ft a{color:var(--muted)}.flinks{display:flex;gap:13px;flex-wrap:wrap;justify-content:flex-end}
  @media(max-width:760px){.top,.stamp,.head,.list,.ft{padding-left:18px;padding-right:18px}nav{display:none}}
</style>

<div class="sheet">
  <div class="top">
    <div class="mark"><span class="sq"></span><a href="/">NUMETAL</a></div>
    <nav>
      <a href="/blog" class="on">Blog</a>
      <a href="/">Studio</a>
      <a href="/fees">Fees</a>
      <a href="/airdrops">Airdrops</a>
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier&nbsp;↗</a>
    </nav>
  </div>
  <div class="stamp">Doc · <b>Blog</b> · notes from the studio</div>
  <div class="dither"></div>

  <main>
    <header class="head">
      <div class="eyebrow">Numetal Labs · Blog</div>
      <h1>Blog<span class="dot">.</span></h1>
      <p class="sub">Notes and posts from Numetal Labs, an agent accelerator studio under Atelier Gökhan.</p>
    </header>

    <section class="list">${rows}
    </section>
  </main>

  <div class="dither"></div>
  <footer class="ft">
    <span>Numetal · an Atelier Gökhan studio · on Base</span>
    <span class="flinks">
      <a href="/">Studio</a>
      <a href="/fees">Fees</a>
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier Gökhan</a>
      <a href="/feed.xml">RSS</a>
      <a href="/sitemap.xml">Sitemap</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </span>
  </footer>
</div>
`;
---
<Base title={title} description={description} canonical={canonical}>
  <Fragment set:html={bodyHtml} />
</Base>
