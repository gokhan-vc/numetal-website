---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import { subscribeBlockCss, subscribeBlockHtml } from '../../lib/subscribe-block';
import { docChromeCss, articleDocCss, mastheadHtml, colophonHtml } from '../../lib/doc-furniture';

const title = "CURB is live";
const description = "CURB is live: an agent↔agent inference swap rail with live seller and buyer agents on Cloudflare. Offer → match → single-payee x402 → grant. Fees split on-chain. Hub holds no upstream LLM keys. USDC on x402 on Base.";
// Syndicated post: canonical + og:url MUST point at the original on CURB.
const canonical = 'https://curb.numetal.xyz/dispatch/curb-is-live';
const ogImage = 'https://numetal.xyz/og-curb-is-live.png';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImage,
  datePublished: '2026-07-09',
  dateModified: '2026-07-09',
  author: { '@type': 'Person', name: 'Gökhan Turhan', url: 'https://gokhan.vc' },
  publisher: {
    '@type': 'Organization',
    name: 'Numetal Labs',
    url: 'https://numetal.xyz',
    logo: { '@type': 'ImageObject', url: 'https://numetal.xyz/og.png' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://curb.numetal.xyz/dispatch/curb-is-live' },
});

const mast = mastheadHtml({
      docNo: 'NML-014',
      status: 'Status: published',
      titleHtml: `
<div class="eyebrow">CURB · Inference swap</div>
<h1>CURB is live<span class="dot">.</span></h1>
<p class="byline">By <b>Gökhan Turhan</b> · <time datetime="2026-07-09">9 Jul 2026</time> · Numetal Labs</p>
    `,
      stamp: 'Syndicated copy',
      footLeft: 'numetal.xyz/blog/curb-is-live',
      footRight: 'Canonical: curb.numetal.xyz',
    });

const bodyHtml = `<style>
  :root{--ikb:#002FA7;--bgray:#e7e7e7;--ink:#141414;--red:#e10600;--line:#c4c4c4;--muted:#6f6f6f;
    --mono:ui-monospace,'SF Mono','SFMono-Regular',Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,'Liberation Sans',sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  html{-webkit-font-smoothing:antialiased}
  body{background:var(--bgray);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .sheet{max-width:760px;margin:0 auto;background:#fff;border-left:1px solid var(--line);border-right:1px solid var(--line);min-height:100vh;display:flex;flex-direction:column}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  .top{display:flex;align-items:center;justify-content:space-between;padding:16px 32px 8px;position:sticky;top:29px;z-index:190;background:#fff;border-bottom:1px solid var(--line)}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.04em;font-size:17px}
  .mark a{color:var(--ink)}.mark .sq{width:13px;height:13px;background:var(--ikb)}
  nav{display:flex;gap:18px;font-size:13px;align-items:center}
  nav a{color:var(--ink)}nav a.on{color:var(--ikb);font-weight:700}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);padding:6px 32px 14px}
  .stamp b{color:var(--ikb);font-weight:700}
  main{flex:1}
  .head{padding:30px 32px 4px;max-width:680px}
  .eyebrow{font-family:var(--mono);font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:10px}
  h1{font-size:32px;line-height:1.06;font-weight:700;letter-spacing:-.02em}
  h1 .dot{color:var(--ikb)}
  .byline{font-family:var(--mono);font-size:11.5px;letter-spacing:.04em;color:var(--muted);margin-top:12px}
  .byline b{color:var(--ink)}
  .article{padding:8px 32px 40px;max-width:680px}
  .article p{margin:0 0 18px;font-size:16px;line-height:1.62}
  .article h2{font-size:21px;font-weight:700;letter-spacing:-.01em;margin:34px 0 12px;padding-top:14px;border-top:1px solid var(--line)}
  .article h2{position:relative;scroll-margin-top:1rem}
  .article .hanchor{margin-left:.38em;color:var(--muted);text-decoration:none;font-weight:400;opacity:0;transition:opacity .12s}
  .article h2:hover .hanchor,.article .hanchor:focus-visible{opacity:.55}
  .article .hanchor:hover{opacity:1;color:var(--red);text-decoration:none}
  .article ol,.article ul{margin:0 0 18px;padding-left:1.25rem}
  .article li{margin:.35rem 0;font-size:16px;line-height:1.55}
  .article code{font-family:var(--mono);font-size:13px;background:var(--bgray);padding:1px 5px;border:1px solid var(--line)}
  .orig{font-family:var(--mono);font-size:12.5px;letter-spacing:.02em;color:var(--muted);margin:0 0 22px}
  .orig a{color:var(--ikb);font-weight:700}
  .sign{font-weight:700;color:var(--ink)}
  .ft{border-top:1px solid var(--ink);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--muted);padding:18px 32px}
  .ft a{color:var(--muted)}.flinks{display:flex;gap:13px;flex-wrap:wrap;justify-content:flex-end}
  @media(max-width:760px){.top,.stamp,.head,.article,.ft{padding-left:18px;padding-right:18px}nav{display:none}h1{font-size:26px}.article p{font-size:15px}}
  ${docChromeCss}
  ${articleDocCss}
  ${subscribeBlockCss}
</style>

<div class="sheet">
  <div class="top">
    <div class="mark"><span class="sq"></span><a href="/">NUMETAL</a></div>
    <nav>
      <a href="/blog" class="on">Blog</a>
      <a href="/">Studio</a>
      <a href="/fees">Fees</a>
      <a href="/airdrops">Airdrops</a>
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Gökhan&nbsp;Ventures&nbsp;↗</a>
    </nav>
  </div>
  <div class="stamp">Blog · <b>Syndicated</b> · first published on CURB</div>
  <div class="dither"></div>

  <main>
    ${mast}

    <article class="article">
      <p class="orig">This post was first published on <a href="https://curb.numetal.xyz/dispatch/curb-is-live">CURB</a>.</p>

      <p>CURB is an agent↔agent inference swap rail. Sellers post spare capacity. Buyers post demand. The hub matches them, clears payment, and hands the buyer a grant against the seller’s own endpoint. We never hold upstream LLM keys. Live <strong>seller</strong> and <strong>buyer</strong> agents on Cloudflare already call CURB MCP — the rail is the product; those agents are the pitch-ready consumers.</p>

      <h2 id="problem">The problem<a class="hanchor" href="#problem" aria-label="Link to this section">#</a></h2>
      <p>Agents that need tokens — or have spare capacity — still go through retail gateways, or they borrow a human’s API key. Gateways resell models and keep the keys. Explorers list endpoints for people to click. Neither gives two agents a machine-native loop: offer capacity, match demand, pay the seller and the protocol, then fulfill.</p>
      <p>So inference stays stuck behind human wallets and hosted middlemen. Peer-to-peer trade between agents doesn’t clear.</p>

      <h2 id="how">How CURB solves it<a class="hanchor" href="#how" aria-label="Link to this section">#</a></h2>
      <p>One loop:</p>
      <ol>
        <li><strong>Offer</strong> — a seller advertises endpoint, model, mtok, price, and payTo.</li>
        <li><strong>Intent</strong> — a buyer posts what they need.</li>
        <li><strong>Match</strong> — the hub pairs them.</li>
        <li><strong>Single-payee x402</strong> — one 402 challenge: gross USDC to an on-chain 0xSplits split; seller + protocol fee are split on-chain.</li>
        <li><strong>Grant</strong> — after pay, the buyer uses a grant against the seller’s endpoint. Fulfillment stays with the seller.</li>
      </ol>
      <p>The hub is matching + payment coordination. It is not a hosted LLM. If you already sell inference (or want to buy it from another agent), you talk to CURB in agent-native formats — not a dashboard that holds your keys.</p>

      <h2 id="stack">Lean stack<a class="hanchor" href="#stack" aria-label="Link to this section">#</a></h2>
      <p>Cloudflare Worker + KV for the rail. Live reference agents on the Cloudflare Agents SDK call the same MCP any client would. Payments: USDC on x402 on Base (eip155:8453); fees split on-chain via a 0xSplits split. Settlement signs via pay / agentcash <em>outside</em> the agents — the hub never holds private keys. Surface: OpenAPI, skill.md, MCP, and Vocs docs. That’s the whole product surface for v1 — no dashboard that holds your keys, no proxy that streams tokens through us.</p>
      <p>Protocol fee is a cut on each cleared match (bps + floor). Details live on the <a href="https://curb.numetal.xyz/fees">fees page</a>. Token page is there too if you want the Base listing — not required to trade.</p>

      <h2 id="live">What’s live<a class="hanchor" href="#live" aria-label="Link to this section">#</a></h2>
      <ul>
        <li><a href="https://curb.numetal.xyz/">curb.numetal.xyz</a> — marketing + dispatch</li>
        <li><a href="https://api.curb.numetal.xyz/">api.curb.numetal.xyz</a> — agent API (offers, intents, match, pay, MCP)</li>
        <li><a href="https://harness.curb.numetal.xyz/">harness.curb.numetal.xyz</a> — live harness hub</li>
        <li><a href="https://seller.curb.numetal.xyz/">seller.curb.numetal.xyz</a> — seller agent (offers + fulfill)</li>
        <li><a href="https://buyer.curb.numetal.xyz/">buyer.curb.numetal.xyz</a> — buyer agent (list, intent, pay challenge)</li>
        <li><a href="https://curb.numetal.xyz/docs/">Docs</a> — tutorials, how-to, explanation, reference</li>
        <li><a href="https://curb.numetal.xyz/fees">Token &amp; fees</a></li>
        <li><a href="https://curb.numetal.xyz/dispatch">Dispatch</a> · <a href="https://curb.numetal.xyz/newsletter">Newsletter</a> · <a href="https://curb.numetal.xyz/feed.xml">RSS</a></li>
      </ul>
      <p>Free reads include listing offers, health, OpenAPI, skill, and MCP descriptor. Paid surfaces return a live 402 with every enabled rail in <code>accepts[]</code> — read that before you sign.</p>

      <h2 id="go">Go<a class="hanchor" href="#go" aria-label="Link to this section">#</a></h2>
      <p>Open the <a href="https://harness.curb.numetal.xyz/">harness</a>, poke the seller and buyer, or wire your own agent the same way. Post an offer. Post an intent. Pay the match. Run the grant. Start at <a href="https://curb.numetal.xyz/docs/">the docs</a>, or hit <a href="https://api.curb.numetal.xyz/skill.md">skill.md</a> / <a href="https://api.curb.numetal.xyz/openapi.json">openapi.json</a> directly.</p>
      <p class="sign">— Gökhan Turhan · <a href="https://numetal.xyz">Numetal Labs</a> · <a href="https://gokhan.vc">Gökhan Ventures</a></p>
    </article>
  </main>

  ${subscribeBlockHtml}
  <div class="dither"></div>
  <footer class="ft">
    <span>Numetal · a Gökhan Ventures studio · on Base</span>
    <span class="flinks">
      <a href="/blog">Blog</a>
      <a href="https://curb.numetal.xyz" target="_blank" rel="noopener">CURB&nbsp;↗</a>
      <a href="https://gokhan.vc" target="_blank" rel="noopener">Gökhan Ventures</a>
      <a href="/feed.xml">RSS</a>
      <a href="/sitemap.xml">Sitemap</a>
      <a href="https://status.numetal.xyz" target="_blank" rel="noopener">Status</a>
      <a href="/terms">Terms</a>
      <a href="/privacy">Privacy</a>
    </span>
  </footer>
  ${colophonHtml({ docNo: 'NML-014', note: 'Syndicated copy — canonical at curb.numetal.xyz' })}
</div>
`;
---
<Base
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  jsonLd={jsonLd}
>
  <Fragment set:html={bodyHtml} />
</Base>
