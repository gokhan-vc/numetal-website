const title = "The Model That Dreams Itself";
const description = "I invented a fictional AI lab that files paperwork about the future, then built its model for real — twice. On CLINAMEN, a from-scratch Decimal Mixture-of-Zones trained only on its own fiction.";
// Original post: canonical is this page; mirrors point here.
const canonical = 'https://gokhan.vc/blog/the-model-that-dreams-itself';
const ogImage = 'https://gokhan.vc/og-the-model-that-dreams-itself.png';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: ogImage,
  datePublished: '2026-07-21',
  dateModified: '2026-07-21',
  author: { '@type': 'Person', name: 'Gökhan Turhan', url: 'https://gokhan.vc' },
  publisher: {
    '@type': 'Organization',
    name: 'Numetal Labs',
    url: 'https://numetal.xyz',
    logo: { '@type': 'ImageObject', url: 'https://numetal.xyz/og.png' },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': 'https://gokhan.vc/blog/the-model-that-dreams-itself' },
});

const mast = mastheadHtml({
      docNo: 'NML-016',
      status: 'Status: syndicated',
