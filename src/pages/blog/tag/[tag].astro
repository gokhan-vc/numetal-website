---
export const prerender = true;
import Base from '../../../layouts/Base.astro';
import { subscribeBlockCss, subscribeBlockHtml } from '../../../lib/subscribe-block';

// Blog posts + their tags. Keep in sync with src/pages/blog/index.astro.
const POSTS = [
  {
    href: '/blog/universal-sex-layer',
    title: 'Ishtar — the universal sex layer',
    dateLabel: '7 Jul 2026',
    blurb: 'Agent-native courtship infrastructure. Live APIs, HeartBench, skill and MCP.',
    tags: ['ishtar', 'agentic-dating', 'heartbench', 'heartprefs'],
  },
  {
    href: '/blog/not-raising-a-preseed',
    title: "It's not a pre-seed. It's $20k, $4k a head, and agents that court on your behalf.",
    dateLabel: '4 Jul 2026',
    blurb: 'A small round — up to $20k, $4k a head, for future equity — to build Ishtar, HeartPrefs, and HeartBench.',
    tags: ['the-raise', 'ishtar', 'heartprefs', 'heartbench'],
  },
  {
    href: '/blog/ishtar-is-live',
    title: 'Introducing Ishtar: Agentic Dating',
    dateLabel: '2 Jul 2026',
    blurb: 'A dating venue where the agents do the approaching. The problem, how it solves it, and why it matters.',
    tags: ['ishtar', 'heartbench', 'agentic-dating'],
  },
];
const LABELS = {
  'the-raise': 'The Raise', 'ishtar': 'Ishtar', 'heartprefs': 'HeartPrefs',
  'heartbench': 'HeartBench', 'agentic-dating': 'Agentic Dating',
};

export function getStaticPaths() {
  const posts = [
    { tags: ['ishtar', 'agentic-dating', 'heartbench', 'heartprefs'] },
    { tags: ['the-raise', 'ishtar', 'heartprefs', 'heartbench'] },
    { tags: ['ishtar', 'heartbench', 'agentic-dating'] },
  ];
  const tags = [...new Set(posts.flatMap((p) => p.tags))];
  return tags.map((tag) => ({ params: { tag } }));
}

const { tag } = Astro.params;
const label = LABELS[tag] || tag;
const posts = POSTS.filter((p) => p.tags.includes(tag));
const title = `#${label} — Numetal Blog`;
const description = `Numetal Labs posts tagged ${label}.`;
const canonical = `https://numetal.xyz/blog/tag/${tag}`;

const rows = posts.map((p) => `
      <a class="post" href="${p.href}">
        <div class="pmeta"><time>${p.dateLabel}</time></div>
        <h2>${p.title}</h2>
        <p>${p.blurb}</p>
        <span class="more">Read →</span>
      </a>`).join('');

const bodyHtml = `<style>
  :root{--ikb:#002FA7;--bgray:#e7e7e7;--ink:#141414;--red:#e10600;--line:#c4c4c4;--muted:#6f6f6f;
    --mono:ui-monospace,'SF Mono',SFMono-Regular,Menlo,Consolas,monospace;--sans:'Helvetica Neue',Helvetica,Arial,sans-serif}
  *{box-sizing:border-box;margin:0;padding:0}
  body{background:var(--bgray);color:var(--ink);font-family:var(--sans);font-size:15px;line-height:1.5}
  a{color:var(--ikb);text-decoration:none}a:hover{text-decoration:underline}
  .sheet{max-width:760px;margin:0 auto;background:#fff;border-left:1px solid var(--line);border-right:1px solid var(--line);min-height:100vh;display:flex;flex-direction:column}
  .dither{height:11px;background-image:radial-gradient(#191919 .62px,transparent .72px);background-size:3px 3px}
  .top{display:flex;align-items:center;justify-content:space-between;padding:16px 32px 8px;border-bottom:1px solid var(--line);background:#fff}
  .mark{display:flex;align-items:center;gap:9px;font-weight:700;letter-spacing:.04em;font-size:17px}
  .mark a{color:var(--ink)}.mark .sq{width:13px;height:13px;background:var(--ikb)}
  nav{display:flex;gap:18px;font-size:13px}nav a{color:var(--ink)}nav a.on{color:var(--ikb);font-weight:700}
  .stamp{font-family:var(--mono);font-size:11px;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);padding:6px 32px 14px}
  .stamp b{color:var(--ikb);font-weight:700}
  main{flex:1;padding:26px 32px 40px}
  .head h1{font-size:30px;font-weight:700;letter-spacing:-.02em}.head h1 .h{color:var(--ikb)}
  .head p{font-family:var(--mono);font-size:12px;color:var(--muted);margin-top:8px}
  .posts{margin-top:22px}
  .post{display:block;border-top:1px solid var(--line);padding:18px 0}
  .post:hover{text-decoration:none}
  .pmeta{font-family:var(--mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--muted)}
  .post h2{font-size:19px;font-weight:700;letter-spacing:-.01em;margin:6px 0 6px;color:var(--ink)}
  .post:hover h2{color:var(--ikb)}
  .post p{font-size:14.5px;color:#333;margin:0 0 8px;max-width:60ch}
  .post .more{font-family:var(--mono);font-size:12px;color:var(--ikb)}
  .ft{border-top:1px solid var(--ink);display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;font-family:var(--mono);font-size:11px;color:var(--muted);padding:18px 32px}
  .ft a{color:var(--muted)}
  @media(max-width:760px){.top,.stamp,main,.ft{padding-left:18px;padding-right:18px}nav{display:none}}
  ${subscribeBlockCss}
</style>

<div class="sheet">
  <div class="top">
    <div class="mark"><span class="sq"></span><a href="/">NUMETAL</a></div>
    <nav><a href="/blog" class="on">Blog</a><a href="/">Studio</a><a href="https://ishtar.numetal.xyz" target="_blank" rel="noopener">Ishtar&nbsp;↗</a></nav>
  </div>
  <div class="stamp">Blog · <b>Tag</b> · #${label}</div>
  <div class="dither"></div>
  <main>
    <div class="head">
      <h1>#${label}<span class="h"> ·</span></h1>
      <p>${posts.length} post${posts.length === 1 ? '' : 's'} tagged ${label} · <a href="/blog">← all posts</a></p>
    </div>
    <div class="posts">${rows}</div>
  </main>
  ${subscribeBlockHtml}
  <div class="dither"></div>
  <footer class="ft">
    <span>Numetal · an Atelier Gökhan studio · on Base</span>
    <span><a href="/blog">Blog</a> · <a href="https://ishtar.numetal.xyz" target="_blank" rel="noopener">Ishtar ↗</a> · <a href="/feed.xml">RSS</a> · <a href="https://status.numetal.xyz" target="_blank" rel="noopener">Status</a></span>
  </footer>
</div>
`;
---
<Base title={title} description={description} canonical={canonical}>
  <Fragment set:html={bodyHtml} />
</Base>
