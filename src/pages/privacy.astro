.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/></svg></a><a href="https://x.com/numetalxyz" target="_blank" rel="noopener" aria-label="X"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a></span>
      <span class="flinks">
    <a href="https://gokhan.vc" target="_blank" rel="noopener">Atelier Gökhan</a>
    <a href="https://github.com/gokhan-vc" target="_blank" rel="noopener">GitHub</a>
    <a href="https://gokhanturhan.com" target="_blank" rel="noopener">gokhanturhan.com</a>
    <a href="/feed.xml">RSS</a>
    <a href="/sitemap.xml">Sitemap</a>
    <a href="/llms.txt">llms.txt</a>
    <a href="https://status.numetal.xyz" target="_blank" rel="noopener">Status</a>
    <a href="/terms">Terms</a>
    <a href="/privacy">Privacy</a>
    <a href="/cookies">Cookies</a>
  </span>
</div></footer>
${colophonHtml({ docNo: 'NML-005', note: 'Filed at numetal.xyz' })}
</div>
`;
---
<Base title={title} description={description} canonical={canonical}>
  <Fragment set:html={bodyHtml} />
</Base>
