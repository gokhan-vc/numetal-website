---
interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  robots?: string;
  jsonLd?: string;
}
const {
  title, description, canonical,
  ogTitle, ogDescription, ogImage,
  robots = 'index, follow, max-image-preview:large',
  jsonLd,
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content={robots} />
  <meta name="theme-color" content="#002FA7" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="apple-touch-icon" href="/favicon-180.png" />
  <link rel="canonical" href={canonical} />
  <link rel="alternate" type="application/rss+xml" title="Numetal" href="/feed.xml" />
  <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Numetal Labs" />
  {ogImage && (
    <>
      <meta property="og:image" content={ogImage} />
      <meta property="og:image:type" content="image/png" />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      <meta property="og:image:alt" content="Numetal — agent accelerator studio. We ship machines that ship themselves." />
    </>
  )}
  <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  {ogImage && <meta name="twitter:image" content={ogImage} />}
  {jsonLd && <script type="application/ld+json" set:html={jsonLd} is:inline />}
</head>
<body>
  <!-- Site-wide Ishtar-launch stock-ticker band. Scrolls like a market ticker (mono, up-tick),
       pauses on hover, static under prefers-reduced-motion. Track = 4 identical segments
       translated -25% (one segment) for a seamless loop that fills wide viewports. -->
  <a class="tickerbar" href="https://ishtar.numetal.xyz" target="_blank" rel="noopener"
     aria-label="Ishtar is live. Agentic dating. Use Ishtar at ishtar.numetal.xyz">
    <span class="tickerbar__tag">● LIVE</span>
    <div class="tickerbar__win">
      <div class="tickerbar__track" aria-hidden="true">
        <span class="tickerbar__seg"><b>ISHTAR</b> <i class="up">▲</i> LIVE <em>◆</em> AGENTIC DATING <em>◆</em> YOUR AGENT DOES THE DATING <em>◆</em> USE ISHTAR <span class="hrt">♥</span> <em>◆</em> ishtar.numetal.xyz <em>◆</em>&nbsp;</span>
        <span class="tickerbar__seg"><b>ISHTAR</b> <i class="up">▲</i> LIVE <em>◆</em> AGENTIC DATING <em>◆</em> YOUR AGENT DOES THE DATING <em>◆</em> USE ISHTAR <span class="hrt">♥</span> <em>◆</em> ishtar.numetal.xyz <em>◆</em>&nbsp;</span>
        <span class="tickerbar__seg"><b>ISHTAR</b> <i class="up">▲</i> LIVE <em>◆</em> AGENTIC DATING <em>◆</em> YOUR AGENT DOES THE DATING <em>◆</em> USE ISHTAR <span class="hrt">♥</span> <em>◆</em> ishtar.numetal.xyz <em>◆</em>&nbsp;</span>
        <span class="tickerbar__seg"><b>ISHTAR</b> <i class="up">▲</i> LIVE <em>◆</em> AGENTIC DATING <em>◆</em> YOUR AGENT DOES THE DATING <em>◆</em> USE ISHTAR <span class="hrt">♥</span> <em>◆</em> ishtar.numetal.xyz <em>◆</em>&nbsp;</span>
      </div>
    </div>
  </a>
  <style>
    .tickerbar{position:sticky;top:0;z-index:200;display:flex;align-items:stretch;overflow:hidden;background:#0c0c0c;color:#fff;
      text-decoration:none;font-family:ui-monospace,"SF Mono",SFMono-Regular,Menlo,Consolas,monospace;
      font-size:12px;letter-spacing:.05em;border-bottom:1px solid #000;}
    .tickerbar:hover{text-decoration:none;}
    .tickerbar__tag{flex:0 0 auto;display:flex;align-items:center;gap:5px;background:#e10600;color:#fff;
      font-weight:700;letter-spacing:.16em;padding:0 12px;font-size:11px;}
    .tickerbar__win{flex:1 1 auto;overflow:hidden;}
    .tickerbar__track{display:flex;width:max-content;padding:7px 0;will-change:transform;
      animation:tickerbar-scroll 32s linear infinite;}
    .tickerbar__seg{flex:0 0 auto;white-space:nowrap;}
    .tickerbar__seg b{font-weight:700;}
    .tickerbar__seg .up{color:#12c06a;font-style:normal;font-size:10px;}
    .tickerbar__seg .hrt{color:#ff5a7a;}
    .tickerbar__seg em{color:#666;font-style:normal;padding:0 .55rem;}
    .tickerbar:hover .tickerbar__track,.tickerbar:focus-visible .tickerbar__track{animation-play-state:paused;}
    @keyframes tickerbar-scroll{from{transform:translateX(0)}to{transform:translateX(-25%)}}
    @media (prefers-reduced-motion: reduce){ .tickerbar__track{animation:none;} }
  </style>
  <!-- Site-wide "we are not raising (live)" banner → the raise dispatch. -->
  <a class="nrbar" href="https://ishtar.numetal.xyz/blog/not-raising-a-preseed/" aria-label="We are not raising — read the raise dispatch">
    <span class="nrbar__dot" aria-hidden="true"></span><span>WE ARE NOT RAISING</span><sup class="nrbar__live">LIVE</sup><span class="nrbar__arw" aria-hidden="true">→</span>
  </a>
  <style>
    .nrbar{display:flex;align-items:center;justify-content:center;gap:8px;background:#e10600;color:#fff;text-decoration:none;
      font-family:ui-monospace,"SF Mono",SFMono-Regular,Menlo,Consolas,monospace;font-size:12px;font-weight:600;letter-spacing:.1em;
      padding:6px 12px;border-bottom:1px solid #000}
    .nrbar:hover{background:#c40500;text-decoration:none}
    .nrbar__dot{width:6px;height:6px;border-radius:50%;background:#fff;animation:nrpulse 1.8s infinite}
    .nrbar__live{font-size:8px;letter-spacing:.16em;vertical-align:super;border:1px solid rgba(255,255,255,.75);padding:1px 4px;border-radius:2px;margin-left:1px}
    .nrbar__arw{opacity:.85}
    @keyframes nrpulse{0%{box-shadow:0 0 0 0 rgba(255,255,255,.6)}70%{box-shadow:0 0 0 6px rgba(255,255,255,0)}100%{box-shadow:0 0 0 0 rgba(255,255,255,0)}}
    @media(prefers-reduced-motion:reduce){.nrbar__dot{animation:none}}
  </style>
  <slot />
  <!-- Site-wide newsletter subscribe + dual-RSS footer. Rendered once here so it
       appears on EVERY page (landing, blog, legal) with zero per-page duplication.
       Colors inherit from the page (currentColor / color:inherit) so it works on
       both light and dark surfaces. The homepage keeps its own "04 Subscribe"
       section; this footer band is additive. -->
  <footer class="site-sub" aria-label="Subscribe to the Numetal newsletter">
    <p class="site-sub__lead">Dispatches from the studio — occasional low-frequency notes on what we ship. No spam.</p>
    <form method="POST" action="https://api.gokhan.vc/newsletter/subscribe" style="display:flex;gap:8px;flex-wrap:wrap;max-width:420px;margin:.75rem 0">
      <input type="email" name="email" required placeholder="you@email.com" autocomplete="email" aria-label="Email" style="flex:1;min-width:190px;padding:10px 12px;border:1px solid currentColor;background:transparent;color:inherit;font:inherit">
      <input type="hidden" name="site" value="numetal">
      <button type="submit" style="padding:10px 18px;border:1px solid currentColor;background:currentColor;color:Canvas;font:inherit;cursor:pointer">Subscribe</button>
    </form>
    <p style="margin:.4rem 0;font-size:.9em;opacity:.8">RSS — <a href="https://numetal.xyz/feed.xml">this site</a> &middot; <a href="https://api.gokhan.vc/feed.xml">everything</a></p>
  </footer>
  <style>
    .site-sub{font-family:var(--mono,ui-monospace,"SF Mono",SFMono-Regular,Menlo,Consolas,monospace);
      padding:22px 32px;border-top:1px solid currentColor;}
    .site-sub__lead{margin:0 0 .25rem;font-size:12px;opacity:.75;}
    .site-sub a{color:inherit;}
    @media(max-width:740px){.site-sub{padding-left:18px;padding-right:18px}}
  </style>
  <script src="/blog-collapse.js" defer></script>
  <script src="/popups.js" defer></script>
</body>
</html>
